/// Production confidential-amount circuits verified on-chain via `sui::groth16`
/// (BN254 — the testnet/mainnet native). These prove the real settlement
/// primitive: a hidden `delta` moves from sender to recipient, balances stay
/// secret, and the proof enforces conservation + no-underflow.
///
/// Bytes generated by circuits/scripts/prove.sh from the production build
/// (Poseidon commitments, 64-bit range checks). The 4 public signals are the
/// commitments cSenderOld / cSenderNew / cRecipientOld / cRecipientNew.
#[test_only]
#[allow(implicit_const_copy)]
module groth16_poc::confidential_tests;

use sui::groth16::{Self, bn254};

fun verify(vk: vector<u8>, inputs: vector<u8>, proof: vector<u8>): bool {
    let curve = bn254();
    let pvk = groth16::prepare_verifying_key(&curve, &vk);
    let public_inputs = groth16::public_proof_inputs_from_bytes(inputs);
    let proof_points = groth16::proof_points_from_bytes(proof);
    groth16::verify_groth16_proof(&curve, &pvk, &public_inputs, &proof_points)
}

// transfer.circom: stream $500→$375, freelancer $0→$125, hidden delta=$125.
const TRANSFER_VK: vector<u8> =
    x"";
const TRANSFER_PROOF: vector<u8> =
    x"48c62568cba82168ed2beb542ebe655de3998b87b6011aa7e5c4c3dbd30c6f27fd6f8c58d846dd7a44eb571d894f02d63e012f4a2ebace0f822d0b5e3678432e465fc57cb724eb4b63e672584b1a684f0bd88350e1513a152cbb7e69b96814a8e519abb893256bf394fd83f296d5c778abf99d25b4e5bbc55125c5b603824f11";
const TRANSFER_INPUTS: vector<u8> =
    x"596ab085862e0366f42e04de276f2b77725fb116487c2b1977efb7f72c999805f5ba88dc63b63544bd3eaad79b0e36436ca59465133cd43c5e0fdd8b37c3b5261ba50e3c7d82093591b1b072c7654c43b8a397ec4a501742199d633486bf851bea3eb9e586671966f301a7e537ce80962d613d68b63f5da10a833d848383322f";

// wrap.circom: enter the confidential balance — public amount $500 bound to a
// commitment with a secret blinding factor. Public signals: [commitment, amount].
const WRAP_VK: vector<u8> =
    x"";
const WRAP_PROOF: vector<u8> =
    x"5edf256a3af545245d7c6b1a2f94732193c0f3f1f7b3f2216a5e696d77cd1b8799ee019bc3c0bda0233a7f13bdf0069cd01f4c0380722c5ba5a50726ca58081937c5252ae0c85bba58affbec9ddfae0dfa9411d423ff994635b68e68d6b5d7ab23d6ec54ac7a47a5270e67bf8d95a4c2840c31b71c0ac54e47f68811136d82a5";
const WRAP_INPUTS: vector<u8> =
    x"72dfed6bf83459ec874c882737f7a9e312f4e0398ac32b38d4c76d8f4d5c14220065cd1d00000000000000000000000000000000000000000000000000000000";

// unwrap.circom: leave to a public coin — reveal $125 and prove it opens the
// freelancer's commitment. Public signals: [commitment, value].
const UNWRAP_VK: vector<u8> =
    x"";
const UNWRAP_PROOF: vector<u8> =
    x"e0be2f8f40f1bdecc6c256098c62996f4fcef0eead822c628877d0c952c97822efcc2275181181e37cc34ee7ef04dd418fd3a9a0bfd61ff82c9cc64c0f3f330d8294a4ba145ed52c254e961293c9ded8e43d1d7827c428072fc4418e9886bf23157d6a9b12a5b98b3d44b2abeb66aa42fc7f715225ada889d5bd7b57d10041ae";
const UNWRAP_INPUTS: vector<u8> =
    x"ea3eb9e586671966f301a7e537ce80962d613d68b63f5da10a833d848383322f4059730700000000000000000000000000000000000000000000000000000000";

#[test]
fun confidential_drip_verifies() {
    assert!(verify(TRANSFER_VK, TRANSFER_INPUTS, TRANSFER_PROOF), 0);
}

#[test]
fun wrap_verifies() {
    assert!(verify(WRAP_VK, WRAP_INPUTS, WRAP_PROOF), 2);
}

#[test]
fun unwrap_verifies() {
    assert!(verify(UNWRAP_VK, UNWRAP_INPUTS, UNWRAP_PROOF), 3);
}

#[test]
fun rejects_forged_commitments() {
    // Flip the last byte of the public commitments — the proof must not verify.
    let mut forged = TRANSFER_INPUTS;
    let last = forged.length() - 1;
    *forged.borrow_mut(last) = 0x00;

    let curve = bn254();
    let pvk = groth16::prepare_verifying_key(&curve, &TRANSFER_VK);
    let inputs = groth16::public_proof_inputs_from_bytes(forged);
    let proof = groth16::proof_points_from_bytes(TRANSFER_PROOF);
    assert!(!groth16::verify_groth16_proof(&curve, &pvk, &inputs, &proof), 1);
}
