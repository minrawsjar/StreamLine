# StreamLine frontend — copy to .env.local and fill in.

# Which network the app talks to by default: mainnet | testnet | devnet
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# Deployed StreamLine Move package IDs (set after publishing the contracts)
NEXT_PUBLIC_PACKAGE_ID_MAINNET=0x0
NEXT_PUBLIC_PACKAGE_ID_TESTNET=0x0

# USDC coin types (override the built-in defaults if needed)
# NEXT_PUBLIC_USDC_TYPE_MAINNET=
# NEXT_PUBLIC_USDC_TYPE_TESTNET=

# === Enoki gasless sponsorship (https://portal.enoki.mystenlabs.com) ===
# SECRET key — server-only, never prefixed NEXT_PUBLIC. When set, all in-app
# transactions (create / approve / raise / dispute / faucet) are gas-sponsored:
# the connected wallet signs but pays no SUI. Without it, the app falls back to
# normal wallet-paid transactions, so local dev still works.
# In the Enoki Portal, enable this key for your network and allow the StreamLine
# package's move-call targets.
ENOKI_PRIVATE_API_KEY=

# zkLogin via Enoki (social login). Public key — exposed to the browser.
# Currently the wallet registration is disabled (needs Sui SDK v2); these are
# reserved for when that migration lands. Sponsorship above does NOT need them.
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Defaults to <origin>/auth/callback if omitted
# NEXT_PUBLIC_ZKLOGIN_REDIRECT_URL=

# Off-chain indexer (added later)
# NEXT_PUBLIC_INDEXER_URL=
# NEXT_PUBLIC_INDEXER_WS_URL=
