# StreamLine frontend — copy to .env (or .env.local) and fill in.

# Which network the app talks to by default: mainnet | testnet | devnet
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# Deployed StreamLine Move package IDs (set after publishing the contracts).
# Leave testnet unset to use the built-in deployed package fallback; if you set
# it, use a real id (NOT 0x0 — that disables on-chain calls and sponsorship).
NEXT_PUBLIC_PACKAGE_ID_MAINNET=0x0
# NEXT_PUBLIC_PACKAGE_ID_TESTNET=

# USDC coin types (override the built-in defaults if needed)
# NEXT_PUBLIC_USDC_TYPE_MAINNET=
# NEXT_PUBLIC_USDC_TYPE_TESTNET=

# === Enoki gasless sponsorship (https://portal.enoki.mystenlabs.com) ===
# SECRET key — server-only, never prefixed NEXT_PUBLIC. When set, all in-app
# transactions (create / approve / raise / dispute / faucet) are gas-sponsored:
# the connected wallet signs but pays no SUI. Without it, the app falls back to
# normal wallet-paid transactions, so local dev still works.
# In the Enoki Portal, the key needs the "Sponsored Transactions" feature, your
# network enabled, and the StreamLine package's move-call targets allowed.
ENOKI_PRIVATE_API_KEY=

# zkLogin via Enoki (social login). PUBLIC key — different from the secret key
# above and safe in the browser. Set BOTH this and the Google client id to make
# "Sign in with Google" appear in the connect modal / onboarding; leave either
# blank to hide social login (extension wallets still work). In the Enoki Portal
# this key needs the zkLogin feature + Google as an auth provider, with your
# origin allowed.
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# OAuth redirect. Defaults to <origin>/app; must be an authorized redirect URI
# on your Google OAuth client.
# NEXT_PUBLIC_ZKLOGIN_REDIRECT_URL=
# Apple: Enoki markets Sign in with Apple, but @mysten/enoki still has no `apple`
# AuthProvider (google / facebook / twitch only). Onboarding shows Apple as
# "coming soon" until the SDK adds it — do not set a client id yet.

# === SuiNS Identity Subnames (via Enoki) ===
# Parent domain you own on SuiNS (testnet first, then mainnet). Display form is
# alice@streamline; on-chain form is alice.streamline.sui.
# Ops checklist (required for minting — resolve works without this):
#   1. Register the domain at https://suins.io on the target network
#   2. Enoki Portal → Subnames → link domain → transfer to Enoki → Publish (LIVE)
#   3. Enable the SUBNAMES feature on NEXT_PUBLIC_ENOKI_API_KEY (zkLogin claim)
#      and on ENOKI_PRIVATE_API_KEY (extension-wallet /api/handle/claim fallback)
# Claims stay available in UI with the default domain; mint fails until LIVE.
NEXT_PUBLIC_SUINS_DOMAIN=streamline.sui
# Same ENOKI_PRIVATE_API_KEY as sponsorship — needs SUBNAMES for /api/handle/claim
# when the user is on an extension wallet (no zkLogin JWT).

# Off-chain indexer (Railway). WS URL is derived (https->wss + /ws) if unset.
NEXT_PUBLIC_INDEXER_URL=https://streamline-production-4739.up.railway.app
# NEXT_PUBLIC_INDEXER_WS_URL=

# === Cloudflare Turnstile (invisible, runs on page load) ===
# Site key is public (browser). Secret key is server-only — never NEXT_PUBLIC.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
