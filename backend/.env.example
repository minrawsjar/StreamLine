# StreamLine backend — copy to .env (per service) or export before running.

# Postgres connection for the indexer.
# Local:   postgres://postgres@localhost:5432/streamline
# Railway: postgresql://postgres:<PASSWORD>@<host>.proxy.rlwy.net:<port>/railway
DATABASE_URL=postgresql://postgres:<PASSWORD>@acela.proxy.rlwy.net:53731/railway

# Sui fullnode JSON-RPC. The keeper's CLI needs a node serving gRPC with no auth
# header — the official fullnode works; keyed JSON-RPC-only endpoints do not.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# StreamLine Move package + module (idles while 0x0).
#  - INDEXER: use the ORIGINAL (type-origin) package id — it filters events by
#    MoveEventModule, stable across upgrades.
#  - KEEPER:  use the LATEST package id (the version with drip_with_yield).
STREAMLINE_PACKAGE_ID=0x0
STREAMLINE_MODULE=stream

# Indexer HTTP port and poll cadence
INDEXER_PORT=8080
POLL_INTERVAL_MS=2000

# === Keeper ===
# Provide the signer via keeper-entrypoint.sh (KEEPER_SUI_PRIVATE_KEY).
# YIELD_VAULT_ID: when set, drips use drip_with_yield so yield-flagged splits
# auto-deposit into the vault; omit for plain drip.
# YIELD_VAULT_ID=0x0
# KEEPER_GAS_BUDGET=100000000
# KEEPER_POLL_INTERVAL_MS=5000
# KEEPER_COOLDOWN_MS=120000
# KEEPER_DRY_RUN=false
