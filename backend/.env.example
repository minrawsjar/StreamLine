# StreamLine backend — copy to .env (per service) or export before running.

# Postgres connection for the indexer.
# Local:   postgres://postgres@localhost:5432/streamline
# Railway: postgresql://postgres:<PASSWORD>@<host>.proxy.rlwy.net:<port>/railway
DATABASE_URL=postgresql://postgres:<PASSWORD>@acela.proxy.rlwy.net:53731/railway

# Sui fullnode JSON-RPC
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Deployed StreamLine Move package + module (poller idles while this is 0x0)
STREAMLINE_PACKAGE_ID=0x0
STREAMLINE_MODULE=stream

# Indexer HTTP port and poll cadence
INDEXER_PORT=8080
POLL_INTERVAL_MS=2000

# Keeper (added next): signer + tip settings
# KEEPER_PRIVATE_KEY=
# KEEPER_TICK_MS=30000
